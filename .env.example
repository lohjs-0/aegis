# ─── Server ───────────────────────────────────────────────
PORT=3000

# ─── Supabase ─────────────────────────────────────────────
# Project URL, found in Supabase dashboard > Settings > API
SUPABASE_URL=https://your-project-id.supabase.co

# Anon/public key, safe to use client-side
SUPABASE_ANON_KEY=your-anon-key

# Service role key, server-side only, never expose to the client
SUPABASE_SERVICE_KEY=your-service-role-key

# ─── Mistral AI ───────────────────────────────────────────
# API key for ÆGIS-BOT, https://console.mistral.ai/api-keys
MISTRAL_KEY=your-mistral-api-key
